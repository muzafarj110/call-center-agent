# ---- Claude ----
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-5
CLAUDE_MAX_TOKENS=800

# ---- WhatsApp Cloud API ----
# Used as fallback when a client has no per-client whatsapp_token in clients.json
WHATSAPP_TOKEN=EAAG...
WHATSAPP_VERIFY_TOKEN=aishop_verify

# ---- Google Sheets service account ----
# Preferred on Railway: paste the whole service-account JSON as one string.
GOOGLE_CREDENTIALS_JSON={"type":"service_account", ...}
# Or, locally, point to a file instead:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ---- Platform ----
CLIENTS_FILE=clients.json
ADMIN_SECRET=change-me           # protects /reload-clients
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=60
PORT=5000
